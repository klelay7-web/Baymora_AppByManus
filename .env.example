# =============================================================================
# CORE APPLICATION
# =============================================================================
NODE_ENV=development
PORT=8080

# =============================================================================
# DATABASE (PostgreSQL recommended for production)
# =============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/baymora_dev
# For SQLite (local development):
DATABASE_URL=sqlite://./data/baymora.db

# =============================================================================
# REDIS (for cache, sessions, job queue)
# =============================================================================
# REDIS_URL=redis://localhost:6379
# Optional: separate Redis URL for job queue
# REDIS_QUEUE_URL=redis://localhost:6379/1

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# Owner/Admin credentials (hashed passwords stored in database)
ADMIN_EMAIL=owner@baymora.com
# Generate strong JWT secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-here-minimum-32-characters-long-required

# =============================================================================
# LLM PROVIDERS
# =============================================================================
# OpenAI (primary provider)
OPENAI_API_KEY=sk-xxx...

# Anthropic Claude (fallback provider)
ANTHROPIC_API_KEY=sk-ant-xxx...

# Vector embeddings (for knowledge base search)
# PINECONE_API_KEY=xxx...
# PINECONE_ENVIRONMENT=us-west1-gcp

# =============================================================================
# PAYMENT (Stripe)
# =============================================================================
STRIPE_SECRET_KEY=sk_live_xxx...
STRIPE_PUBLIC_KEY=pk_live_xxx...
STRIPE_WEBHOOK_SECRET=whsec_xxx...
STRIPE_SUCCESS_URL=https://baymora.com/chat?upgraded=1
STRIPE_CANCEL_URL=https://baymora.com/chat

# Frontend base URL for Stripe redirect
STRIPE_SUCCESS_URL=http://localhost:5173/checkout/success
STRIPE_CANCEL_URL=http://localhost:5173/checkout/cancelled

# =============================================================================
# STORAGE (S3 for PDFs, images)
# =============================================================================
# AWS_S3_BUCKET=baymora-production
# AWS_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=xxx...
# AWS_SECRET_ACCESS_KEY=xxx...
# Or use Cloudflare R2:
# R2_ACCOUNT_ID=xxx...
# R2_ACCESS_KEY_ID=xxx...
# R2_SECRET_ACCESS_KEY=xxx...

# =============================================================================
# ERROR TRACKING & MONITORING
# =============================================================================
# SENTRY_DSN=https://xxx@sentry.io/xxx

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_VECTOR_SEARCH=false
FEATURE_AFFILIATION_TRACKING=false
FEATURE_CONCIERGE_AUTO_REQUEST=false

# =============================================================================
# API RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# CORS & SECURITY
# =============================================================================
CORS_ORIGIN=http://localhost:5173

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=debug
