# ─── Baymora — Variables d'environnement ──────────────────────────────────────
# Copiez ce fichier en .env et remplissez les valeurs.
# Ne commitez jamais ce fichier avec de vraies valeurs.

# Serveur
NODE_ENV=development
PORT=8080
CORS_ORIGIN=http://localhost:8080

# Sécurité JWT — OBLIGATOIRE (min 32 caractères)
JWT_SECRET=CHANGE_ME_minimum_32_characters_long_secret_key

# Administration
ADMIN_EMAIL=owner@baymora.com

# ─── Intelligence Artificielle ────────────────────────────────────────────────
# Anthropic Claude (principal)
ANTHROPIC_API_KEY=

# OpenAI (fallback optionnel — Phase 2)
# OPENAI_API_KEY=

# ─── Base de données (Phase 1) ────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/baymora

# ─── Cache & Queue (Phase 2) ──────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── Paiement (Phase 2) ───────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_COMFORT=
# STRIPE_PRICE_ID_PREMIUM=
# STRIPE_PRICE_ID_LUXURY=

# ─── Monitoring (Phase 3) ─────────────────────────────────────────────────────
# SENTRY_DSN=
