// Baymora — Schéma PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Utilisateurs ─────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  pseudo         String   @unique
  prenom         String?
  email          String?  @unique
  mode           String   @default("fantome")
  circle         String   @default("decouverte")
  messagesUsed   Int      @default(0)
  messagesLimit  Int      @default(20)
  passwordHash   String?
  googleId       String?  @unique
  preferences    Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  companions     TravelCompanion[]
  dates          ImportantDate[]
  conversations  Conversation[]

  @@map("users")
}

// ─── Compagnons de voyage ─────────────────────────────────────────────────────

model TravelCompanion {
  id               String   @id @default(uuid())
  userId           String
  name             String
  relationship     String   @default("ami")
  birthday         String?
  age              Int?
  heightCm         Int?
  weightKg         Float?
  clothingSize     String?
  shoeSize         Float?
  diet             String?
  notes            String?
  preferences      Json     @default("{}")
  firstMentionedAt DateTime @default(now())
  lastSeenWith     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("travel_companions")
}

// ─── Dates importantes ────────────────────────────────────────────────────────

model ImportantDate {
  id          String   @id @default(uuid())
  userId      String
  label       String
  date        String
  recurring   Boolean  @default(true)
  contactName String?
  notes       String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("important_dates")
}

// ─── Conversations ────────────────────────────────────────────────────────────

model Conversation {
  id             String    @id @default(uuid())
  userId         String
  title          String
  language       String    @default("fr")
  pendingProfile Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@map("conversations")
}

// ─── Messages ─────────────────────────────────────────────────────────────────

model Message {
  id             String       @id @default(uuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}
