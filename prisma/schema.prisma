// Baymora — Schéma PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Utilisateurs ─────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  pseudo         String   @unique
  prenom         String?
  email          String?  @unique
  mode           String   @default("fantome")
  circle         String   @default("decouverte")
  // ─── Système de crédits ───────────────────────────────────────────────────
  creditsUsed    Int      @default(0)         // crédits consommés ce mois
  creditsLimit   Int      @default(15)        // plafond mensuel (15 = découverte)
  creditsResetAt DateTime @default(now())     // date du prochain reset
  perplexityUsed Int      @default(0)         // recherches Perplexity ce mois
  perplexityLimit Int     @default(3)         // plafond Perplexity mensuel
  // Legacy (kept for backward compat)
  messagesUsed   Int      @default(0)
  messagesLimit  Int      @default(20)
  // ─── Auth ─────────────────────────────────────────────────────────────────
  passwordHash   String?
  googleId       String?  @unique
  preferences    Json     @default("{}")
  // ─── Baymora Club ─────────────────────────────────────────────────────────
  clubPoints     Int      @default(0)
  clubVerified   Boolean  @default(false)
  invitedById    String?                      // userId de qui les a invités
  // ─── Notifications ────────────────────────────────────────────────────────
  phone          String?                      // ex: +33612345678
  notifSms       Boolean  @default(false)     // SMS actif
  notifWhatsApp  Boolean  @default(false)     // WhatsApp actif
  notifFlights   Boolean  @default(true)      // rappels vols J-1
  notifCheckin   Boolean  @default(true)      // rappels check-in hôtel
  notifBirthdays Boolean  @default(true)      // alertes anniversaires
  notifOffers    Boolean  @default(true)      // offres partenaires
  // ─── Stripe ───────────────────────────────────────────────────────────────
  stripeCustomerId   String?  @unique
  stripeSubscriptionId String?
  // ─── Résiliation & rétention ──────────────────────────────────────────────
  cancelledAt    DateTime?                     // date de résiliation
  purgeAt        DateTime?                     // date de suppression définitive (cancelledAt + 90 jours)
  cancelReason   String?                       // motif de départ (optionnel)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  companions     TravelCompanion[]
  dates          ImportantDate[]
  conversations  Conversation[]
  inviteCode     InviteCode?
  pointHistory   PointTransaction[]
  trips              Trip[]
  conciergeRequests  ConciergeRequest[]
  creditPurchases    CreditPurchase[]
  giftsSent          Gift[]     @relation("GiftSender")
  giftsReceived      Gift[]     @relation("GiftRecipient")
  tripShares         TripShare[]
  prestataire        Prestataire?

  @@index([email])
  @@index([circle])
  @@index([creditsResetAt])
  @@index([cancelledAt])
  @@index([stripeCustomerId])
  @@index([createdAt])
  @@map("users")
}

// ─── Compagnons de voyage ─────────────────────────────────────────────────────

model TravelCompanion {
  id               String   @id @default(uuid())
  userId           String
  name             String
  relationship     String   @default("ami")
  birthday         String?
  age              Int?
  heightCm         Int?
  weightKg         Float?
  clothingSize     String?
  shoeSize         Float?
  diet             String?
  notes            String?
  preferences      Json     @default("{}")
  firstMentionedAt DateTime @default(now())
  lastSeenWith     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("travel_companions")
}

// ─── Dates importantes ────────────────────────────────────────────────────────

model ImportantDate {
  id          String   @id @default(uuid())
  userId      String
  label       String
  date        String
  recurring   Boolean  @default(true)
  contactName String?
  notes       String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("important_dates")
}

// ─── Conversations ────────────────────────────────────────────────────────────

model Conversation {
  id             String    @id @default(uuid())
  userId         String
  title          String
  language       String    @default("fr")
  pendingProfile Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@index([userId, createdAt])
  @@map("conversations")
}

// ─── Messages ─────────────────────────────────────────────────────────────────

model Message {
  id             String       @id @default(uuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ─── Baymora Club ─────────────────────────────────────────────────────────────

model InviteCode {
  id         String   @id @default(uuid())
  userId     String   @unique
  code       String   @unique
  usedCount  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("invite_codes")
}

model PointTransaction {
  id          String   @id @default(uuid())
  userId      String
  type        String   // registration|invitation_sent|invitation_received|profile|message_milestone|partner_booking|admin_grant
  points      Int      // positif = gagné, négatif = dépensé
  description String
  refId       String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("point_transactions")
}

// ─── Voyages sauvegardés ─────────────────────────────────────────────────────

model Trip {
  id           String   @id @default(uuid())
  userId       String
  title        String                         // "Séjour à Kyoto · Avr 2026"
  destination  String?
  dates        String?
  duration     String?
  travelers    Int?
  budget       String?
  planData     Json                           // TripPlan JSON complet
  status       String   @default("planning") // planning|confirmed|past
  sourceConvId String?                        // conversationId d'origine
  // ─── Partage ──────────────────────────────────────────────────────────────
  shareCode    String?  @unique              // code unique de partage (ex: "KYOTO-2026-A3K7")
  isPublic     Boolean  @default(false)      // visible via lien de partage
  shareCount   Int      @default(0)          // nombre de fois partagé
  forkedFromId String?                       // si copié depuis un autre trip
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  forkedFrom   Trip?    @relation("TripFork", fields: [forkedFromId], references: [id], onDelete: SetNull)
  forks        Trip[]   @relation("TripFork")
  shares       TripShare[]

  @@index([userId, status])
  @@index([forkedFromId])
  @@map("trips")
}

// ─── Partage de voyages & commissions ────────────────────────────────────────

model TripShare {
  id               String   @id @default(uuid())
  tripId           String
  sharerId         String                       // qui partage
  viewCount        Int      @default(0)         // nombre de vues du lien
  forkCount        Int      @default(0)         // combien l'ont copié dans leur profil
  signupCount      Int      @default(0)         // inscriptions via ce partage
  bookingCount     Int      @default(0)         // réservations partenaires via ce partage
  creditsEarned    Int      @default(0)         // crédits gagnés par le shareur
  commissionEarned Float    @default(0)         // commission en € gagnée
  createdAt        DateTime @default(now())

  trip             Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  sharer           User     @relation(fields: [sharerId], references: [id], onDelete: Cascade)

  @@index([sharerId, createdAt])
  @@index([tripId])
  @@map("trip_shares")
}

// ─── Conciergerie ────────────────────────────────────────────────────────────

model ConciergeRequest {
  id          String   @id @default(uuid())
  userId      String
  title       String
  destination String?
  dates       String?
  travelers   Int?
  budget      String?
  message     String
  status      String   @default("pending")  // pending|in_progress|completed|cancelled
  priority    String   @default("normal")   // normal|high|urgent
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    ConciergeMessage[]

  @@map("concierge_requests")
}

model ConciergeMessage {
  id        String   @id @default(uuid())
  requestId String
  fromAdmin Boolean  @default(false)
  content   String
  createdAt DateTime @default(now())

  request   ConciergeRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("concierge_messages")
}

// ─── Achats de crédits / déblocages ──────────────────────────────────────────

model CreditPurchase {
  id          String   @id @default(uuid())
  userId      String?                        // null si achat guest (par email)
  guestEmail  String?                        // email guest pour déblocage unitaire
  type        String                         // unlock_single | pack_50 | pack_150 | pack_500 | pack_1000
  credits     Int                            // nombre de crédits achetés
  amountEur   Int                            // montant en centimes
  stripeSessionId String? @unique
  status      String   @default("pending")   // pending | completed | refunded
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("credit_purchases")
}

// ─── Sessions guest (tracking crédits sans compte) ──────────────────────────

model GuestSession {
  id             String   @id @default(uuid())
  fingerprint    String   @unique             // hash IP + user-agent
  creditsUsed    Int      @default(0)
  creditsLimit   Int      @default(15)
  perplexityUsed Int      @default(0)
  perplexityLimit Int     @default(3)
  createdAt      DateTime @default(now())
  expiresAt      DateTime                     // expire après 7 jours

  @@index([expiresAt])
  @@map("guest_sessions")
}

// ─── Partenaires Baymora ──────────────────────────────────────────────────────

model Partner {
  id               String   @id @default(uuid())
  slug             String   @unique
  name             String
  type             String                        // hotel|spa|restaurant|transport|activity|villa
  status           String   @default("pending")  // pending|testing|approved|rejected
  city             String
  address          String?
  country          String   @default("FR")
  description      String?
  vibe             String?                       // "Chic, discret, romantique"

  // Média
  photos           Json     @default("[]")       // string[] — URLs
  videoUrl         String?
  virtualTourUrl   String?
  mapQuery         String?                       // ex: "Hôtel Byblos, Saint-Tropez"

  // Tags & niveau
  tags             Json     @default("[]")       // ["Piscine", "Spa", "Vue mer"]
  priceLevel       Int      @default(3)          // 1-4

  // Vérification Baymora
  verificationLevel String  @default("auto")     // auto | human_verified
  verifiedById     String?                        // ID du prestataire qui a vérifié
  verifiedAt       DateTime?
  verificationReport String?                      // rapport de visite terrain
  badgeType        String   @default("listed")    // listed | verified | premium

  // Affiliation
  affiliateCode    String   @unique @default("")
  commissionRate   Float    @default(15)
  testCostAmount   Float    @default(0)
  totalCommissions Float    @default(0)

  // Contact
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  website          String?

  // Application message
  applyMessage     String?

  // Auth partenaire (magic link)
  loginToken       String?  @unique           // token temporaire pour connexion
  loginTokenExpiry DateTime?

  // Metadata
  approvedAt       DateTime?
  approvedBy       String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  offers           PartnerOffer[]
  affiliateClicks  AffiliateClick[]
  visits           PartnerVisit[]

  @@map("partners")
}

model PartnerOffer {
  id            String   @id @default(uuid())
  partnerId     String
  type          String                       // stay_1night|stay_2nights|stay_3nights|day_pass|spa|massage|activity|custom
  title         String
  description   String?
  normalPrice   Float?
  baymoraPrice  Float?
  currency      String   @default("EUR")
  bookingUrl    String?
  minTier       String   @default("crystal") // crystal|gold|platinum|diamond
  // ─── Catégorie d'offre ────────────────────────────────────────────────────
  category      String   @default("escapade") // escapade = "Échappées Baymora" (prix réduit) | experience = "Expériences Privées" (privilèges VIP)
  premiumPerks  Json     @default("[]")       // ["Champagne offert", "Surclassement", "Chauffeur privé", "Accès VIP"]
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  partner       Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("partner_offers")
}

// ─── Cadeaux ─────────────────────────────────────────────────────────────────

model Gift {
  id             String   @id @default(uuid())
  senderId       String                          // qui offre
  recipientId    String?                         // destinataire (si déjà inscrit)
  recipientEmail String?                         // ou email du destinataire (pas encore inscrit)
  type           String                          // subscription | credits | boutique_item
  // Détails selon le type
  giftCircle     String?                         // plan offert (voyageur, explorateur...)
  giftMonths     Int?                            // durée du plan offert (1, 3, 6, 12 mois)
  giftCredits    Int?                            // nombre de crédits offerts
  giftItemId     String?                         // ID produit boutique (futur)
  giftItemName   String?                         // nom du produit (affichage)
  // Message personnel
  message        String?                         // "Joyeux anniversaire !"
  // Paiement
  amountEur      Int      @default(0)            // montant payé en centimes
  stripeSessionId String? @unique
  // État
  status         String   @default("pending")    // pending | paid | claimed | expired
  claimedAt      DateTime?                       // date de réclamation par le destinataire
  expiresAt      DateTime?                       // expiration si non réclamé (90 jours)
  createdAt      DateTime @default(now())

  sender         User     @relation("GiftSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient      User?    @relation("GiftRecipient", fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([senderId, createdAt])
  @@index([recipientEmail])
  @@index([status, expiresAt])
  @@map("gifts")
}

// ─── Tracking affilié ────────────────────────────────────────────────────────

model AffiliateClick {
  id            String    @id @default(uuid())
  partnerId     String
  affiliateCode String
  userId        String?                        // si user connecté
  offerId       String?                        // offre cliquée
  ip            String?
  userAgent     String?
  convertedAt   DateTime?                      // si réservation confirmée
  commissionEur Float?
  createdAt     DateTime  @default(now())

  partner       Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, createdAt])
  @@index([userId])
  @@index([convertedAt])
  @@map("affiliate_clicks")
}

// ─── Prestataires Baymora (terrain) ──────────────────────────────────────────

model Prestataire {
  id                String   @id @default(uuid())
  userId            String   @unique              // lié à un compte User
  status            String   @default("active")   // active | suspended | terminated
  region            String                        // zone géographique
  speciality        String?                       // hotel | restaurant | spa | all

  // Activité
  visitsCompleted   Int      @default(0)
  partnersRecruited Int      @default(0)
  fichesCreated     Int      @default(0)

  // Rémunération
  ratePerVisit      Float    @default(50)         // € par visite validée
  ratePerFiche      Float    @default(30)         // € par fiche créée et publiée
  ratePerRecruit    Float    @default(100)        // € par partenaire recruté et approuvé
  commissionOnRecruit Float  @default(10)         // % commission sur partenaires recrutés (12 mois)
  totalEarned       Float    @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id])
  visits            PartnerVisit[]

  @@map("prestataires")
}

model PartnerVisit {
  id                String   @id @default(uuid())
  prestataireId     String
  partnerId         String?                        // si partenaire existant
  // Rapport de visite
  establishmentName String
  establishmentType String                         // hotel | spa | restaurant | activity | villa
  city              String
  visitDate         DateTime
  report            String                         // rapport écrit détaillé
  photos            Json     @default("[]")        // URLs photos prises sur place
  rating            Int?                           // note interne 1-10
  recommendation    String?                        // approved | needs_work | rejected
  // État
  status            String   @default("draft")     // draft | submitted | reviewed | published
  reviewedBy        String?                        // admin qui a relu
  reviewNotes       String?
  publishedAt       DateTime?
  createdAt         DateTime @default(now())

  prestataire       Prestataire @relation(fields: [prestataireId], references: [id], onDelete: Cascade)
  partner           Partner?    @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  @@index([prestataireId, createdAt])
  @@index([partnerId])
  @@map("partner_visits")
}
