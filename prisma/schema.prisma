// Baymora — Schéma PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Utilisateurs ─────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  pseudo         String   @unique
  prenom         String?
  email          String?  @unique
  mode           String   @default("fantome")
  circle         String   @default("decouverte")
  messagesUsed   Int      @default(0)
  messagesLimit  Int      @default(20)
  passwordHash   String?
  googleId       String?  @unique
  preferences    Json     @default("{}")
  // Baymora Club
  clubPoints     Int      @default(0)
  clubVerified   Boolean  @default(false)
  invitedById    String?                      // userId de qui les a invités
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  companions     TravelCompanion[]
  dates          ImportantDate[]
  conversations  Conversation[]
  inviteCode     InviteCode?
  pointHistory   PointTransaction[]

  @@map("users")
}

// ─── Compagnons de voyage ─────────────────────────────────────────────────────

model TravelCompanion {
  id               String   @id @default(uuid())
  userId           String
  name             String
  relationship     String   @default("ami")
  birthday         String?
  age              Int?
  heightCm         Int?
  weightKg         Float?
  clothingSize     String?
  shoeSize         Float?
  diet             String?
  notes            String?
  preferences      Json     @default("{}")
  firstMentionedAt DateTime @default(now())
  lastSeenWith     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("travel_companions")
}

// ─── Dates importantes ────────────────────────────────────────────────────────

model ImportantDate {
  id          String   @id @default(uuid())
  userId      String
  label       String
  date        String
  recurring   Boolean  @default(true)
  contactName String?
  notes       String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("important_dates")
}

// ─── Conversations ────────────────────────────────────────────────────────────

model Conversation {
  id             String    @id @default(uuid())
  userId         String
  title          String
  language       String    @default("fr")
  pendingProfile Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@map("conversations")
}

// ─── Messages ─────────────────────────────────────────────────────────────────

model Message {
  id             String       @id @default(uuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ─── Baymora Club ─────────────────────────────────────────────────────────────

model InviteCode {
  id         String   @id @default(uuid())
  userId     String   @unique
  code       String   @unique
  usedCount  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("invite_codes")
}

model PointTransaction {
  id          String   @id @default(uuid())
  userId      String
  type        String   // registration|invitation_sent|invitation_received|profile|message_milestone|partner_booking|admin_grant
  points      Int      // positif = gagné, négatif = dépensé
  description String
  refId       String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_transactions")
}

// ─── Partenaires Baymora ──────────────────────────────────────────────────────

model Partner {
  id               String   @id @default(uuid())
  slug             String   @unique
  name             String
  type             String                        // hotel|spa|restaurant|transport|activity|villa
  status           String   @default("pending")  // pending|testing|approved|rejected
  city             String
  address          String?
  country          String   @default("FR")
  description      String?
  vibe             String?                       // "Chic, discret, romantique"

  // Média
  photos           Json     @default("[]")       // string[] — URLs
  videoUrl         String?
  virtualTourUrl   String?
  mapQuery         String?                       // ex: "Hôtel Byblos, Saint-Tropez"

  // Tags & niveau
  tags             Json     @default("[]")       // ["Piscine", "Spa", "Vue mer"]
  priceLevel       Int      @default(3)          // 1-4

  // Affiliation
  affiliateCode    String   @unique @default("")
  commissionRate   Float    @default(15)
  testCostAmount   Float    @default(0)
  totalCommissions Float    @default(0)

  // Contact
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  website          String?

  // Application message
  applyMessage     String?

  // Metadata
  approvedAt       DateTime?
  approvedBy       String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  offers           PartnerOffer[]

  @@map("partners")
}

model PartnerOffer {
  id            String   @id @default(uuid())
  partnerId     String
  type          String                       // stay_1night|stay_2nights|stay_3nights|day_pass|spa|massage|activity|custom
  title         String
  description   String?
  normalPrice   Float?
  baymoraPrice  Float?
  currency      String   @default("EUR")
  bookingUrl    String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  partner       Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("partner_offers")
}
